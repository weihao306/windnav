APP_ENV=development
HTTP_ADDR=:8080

# sqlite or postgres
DB_DRIVER=sqlite
DB_SQLITE_PATH=./data/windnav.db
DATABASE_URL=postgres://windnav:windnav_password@localhost:5432/windnav?sslmode=disable

JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL=24h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# Set to frontend/dist when serving built frontend from backend.
STATIC_DIR=
